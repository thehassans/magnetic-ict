generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum OrderStatus {
  CART
  PENDING
  PAID
  FAILED
  CANCELLED
  FULFILLED
}

enum PaymentMethod {
  UNKNOWN
  STRIPE
  PAYPAL
  APPLE_PAY
  GOOGLE_PAY
  MANUAL
}

enum OrderEventType {
  CREATED
  PAID
  FAILED
  CANCELLED
  FULFILLED
}

enum DomainStatus {
  PENDING
  ACTIVE
  EXPIRED
  FAILED
  CANCELLED
}

enum DomainTransactionType {
  REGISTRATION
  RENEWAL
  DNS_CHANGE
  NAMESERVER_UPDATE
}

enum DomainTransactionStatus {
  PENDING
  PAID
  ACTIVE
  FAILED
  CANCELLED
}

enum DnsRecordType {
  A
  AAAA
  CNAME
  MX
  TXT
  NS
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String    @unique
  name          String?
  role          UserRole  @default(USER)
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  domains       Domain[]
  transactions  Transaction[]
  dnsRecords    DnsRecord[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Domain {
  id                String         @id @default(auto()) @map("_id") @db.ObjectId
  userId            String         @db.ObjectId
  orderReference    String?
  domain            String         @unique
  status            DomainStatus   @default(PENDING)
  years             Int            @default(1)
  privacyProtection Boolean        @default(true)
  autoRenew         Boolean        @default(false)
  purchasePrice     Float          @default(0)
  renewalPrice      Float          @default(0)
  currency          String         @default("USD")
  registrarReference String?
  provider          String         @default("manual")
  nameservers       String[]
  registeredAt      DateTime?
  expiresAt         DateTime?
  errorMessage      String?
  whoisSnapshot     Json?
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions      Transaction[]
  dnsRecords        DnsRecord[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([userId])
  @@index([orderReference])
}

model Transaction {
  id                String                  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String                  @db.ObjectId
  domainId          String?                 @db.ObjectId
  orderReference    String?
  domainSnapshot    String
  type              DomainTransactionType
  status            DomainTransactionStatus @default(PENDING)
  amount            Float                   @default(0)
  currency          String                  @default("USD")
  paymentMethod     PaymentMethod           @default(MANUAL)
  paymentReference  String?
  registrarReference String?
  metadata          Json?
  completedAt       DateTime?
  failedAt          DateTime?
  errorMessage      String?
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain            Domain?                 @relation(fields: [domainId], references: [id], onDelete: SetNull)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([userId])
  @@index([domainId])
  @@index([orderReference])
}

model DnsRecord {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  userId      String        @db.ObjectId
  domainId    String        @db.ObjectId
  externalId  String?
  type        DnsRecordType
  name        String
  value       String
  ttl         Int           @default(3600)
  priority    Int?
  source      String        @default("platform")
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain       Domain       @relation(fields: [domainId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId])
  @@index([domainId])
}

model Service {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  catalogKey  String        @unique
  name        String
  description String
  image       String?
  features    Json
  category    String
  tiers       ServiceTier[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ServiceTier {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  catalogKey String  @unique
  serviceId String   @db.ObjectId
  name      String
  price     Float
  features  Json
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([serviceId])
}

model Order {
  id                  String        @id @default(auto()) @map("_id") @db.ObjectId
  userId              String        @db.ObjectId
  serviceTierId       String        @db.ObjectId
  status              OrderStatus   @default(CART)
  paymentMethod       PaymentMethod @default(UNKNOWN)
  currency            String        @default("USD")
  amount              Float
  serviceNameSnapshot String
  tierNameSnapshot    String
  paymentReference    String?
  invoiceNumber       String?
  paidAt              DateTime?
  failedAt            DateTime?
  cancelledAt         DateTime?
  fulfilledAt         DateTime?
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceTier         ServiceTier   @relation(fields: [serviceTierId], references: [id], onDelete: Restrict)
  events              OrderEvent[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([userId])
  @@index([serviceTierId])
  @@index([paymentReference])
}

model OrderEvent {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  orderId        String         @db.ObjectId
  type           OrderEventType
  statusSnapshot OrderStatus
  paymentRef     String?
  metadata       Json?
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())

  @@index([orderId])
}

model Review {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  authorName String
  authorRole String
  rating     Int      @default(5)
  content    String
  avatarUrl  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Setting {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailOtp {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  email      String
  tokenHash  String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, expiresAt])
}

model Account {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String   @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
